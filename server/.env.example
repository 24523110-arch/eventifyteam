PORT=4000

# PostgreSQL connection string used by src/db/pool.js.
# Local example: postgresql://postgres:postgres@localhost:5432/eventify
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/eventify

# Which event the API serves (matches the seeded row in db/seed.sql).
DEFAULT_EVENT_ID=evt-001

# Optional: if set, the report generator will call the Claude API for a
# richer narrative insight. If unset or the call fails, the server
# automatically falls back to a deterministic local summary.
ANTHROPIC_API_KEY=
